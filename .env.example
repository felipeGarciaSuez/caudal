DJANGO_SETTINGS_MODULE=config.settings.dev
SECRET_KEY=changeme
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
# En dev, si DATABASE_URL queda vacía se usa SQLite (db.sqlite3) como fallback.
# En prod: la URL de Neon (postgres://...).
DATABASE_URL=
TIME_ZONE=America/Argentina/Cordoba
LANGUAGE_CODE=es-ar
# Ruta del panel de admin. En prod conviene moverla a algo difícil de adivinar
# (mantené la barra final). En dev podés dejar admin/.
ADMIN_URL=admin/
# Fuerza bruta en el login (django-axes): intentos permitidos y horas de bloqueo.
AXES_FAILURE_LIMIT=5
AXES_COOLOFF_HOURS=1
# Detrás de un proxy (Render), cuántos proxies hay delante para leer bien la IP.
AXES_PROXY_COUNT=1
